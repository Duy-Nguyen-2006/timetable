  it('teacher_max_consecutive handles split sessions without false positive', () => {
    const localSchedule = [
      entry('6A', 'mon', 1, 'Toán', 'Sơn'),
      entry('6A', 'mon', 2, 'Toán', 'Sơn'),
      entry('6A', 'mon', 5, 'Toán', 'Sơn'),
