import { useState, useEffect } from 'react'

const STORAGE_KEY = 'timetable_data'

const DEFAULT_SUBJECTS = [
  { id: '1', name: 'Mathematics', color: '#3B82F6' },
  { id: '2', name: 'Physics', color: '#8B5CF6' },
  { id: '3', name: 'Chemistry', color: '#10B981' },
  { id: '4', name: 'English', color: '#F59E0B' },
  { id: '5', name: 'History', color: '#EF4444' },
  { id: '6', name: 'Computer Science', color: '#06B6D4' },
]

const DEFAULT_SLOTS = [
  { id: 's1', day: 1, startHour: 8, startMin: 0, endHour: 9, endMin: 30, subjectId: '1', room: 'Room 101', teacher: 'Mr. Smith' },
  { id: 's2', day: 1, startHour: 10, startMin: 0, endHour: 11, endMin: 30, subjectId: '2', room: 'Lab A', teacher: 'Dr. Jones' },
  { id: 's3', day: 2, startHour: 8, startMin: 0, endHour: 9, endMin: 30, subjectId: '3', room: 'Lab B', teacher: 'Ms. Davis' },
  { id: 's4', day: 2, startHour: 11, startMin: 0, endHour: 12, endMin: 30, subjectId: '4', room: 'Room 202', teacher: 'Mrs. Wilson' },
  { id: 's5', day: 3, startHour: 9, startMin: 0, endHour: 10, endMin: 30, subjectId: '5', room: 'Room 303', teacher: 'Mr. Brown' },
  { id: 's6', day: 3, startHour: 13, startMin: 0, endHour: 14, endMin: 30, subjectId: '6', room: 'Computer Lab', teacher: 'Mr. Tech' },
  { id: 's7', day: 4, startHour: 8, startMin: 0, endHour: 9, endMin: 30, subjectId: '1', room: 'Room 101', teacher: 'Mr. Smith' },
  { id: 's8', day: 4, startHour: 10, startMin: 0, endHour: 11, endMin: 30, subjectId: '6', room: 'Computer Lab', teacher: 'Mr. Tech' },
  { id: 's9', day: 5, startHour: 9, startMin: 0, endHour: 10, endMin: 30, subjectId: '2', room: 'Lab A', teacher: 'Dr. Jones' },
  { id: 's10', day: 5, startHour: 11, startMin: 0, endHour: 12, endMin: 30, subjectId: '4', room: 'Room 202', teacher: 'Mrs. Wilson' },
]

function load() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY)
    if (raw) return JSON.parse(raw)
  } catch {}
  return null
}

function save(data) {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data))
  } catch {}
}

export function useTimetable() {
  const [state, setState] = useState(() => {
    const saved = load()
    return saved || { subjects: DEFAULT_SUBJECTS, slots: DEFAULT_SLOTS }
  })

  useEffect(() => {
    save(state)
  }, [state])

  const addSubject = (subject) => {
    const newSubject = { ...subject, id: Date.now().toString() }
    setState(s => ({ ...s, subjects: [...s.subjects, newSubject] }))
    return newSubject
  }

  const deleteSubject = (id) => {
    setState(s => ({
      subjects: s.subjects.filter(sub => sub.id !== id),
      slots: s.slots.filter(slot => slot.subjectId !== id),
    }))
  }

  const addSlot = (slot) => {
    const newSlot = { ...slot, id: Date.now().toString() }
    setState(s => ({ ...s, slots: [...s.slots, newSlot] }))
  }

  const deleteSlot = (id) => {
    setState(s => ({ ...s, slots: s.slots.filter(slot => slot.id !== id) }))
  }

  return { ...state, addSubject, deleteSubject, addSlot, deleteSlot }
}
