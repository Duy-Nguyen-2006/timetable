try:
    _max_seconds = float(_os.environ.get("SOLVER_MAX_SECONDS", "") or 60.0)
except Exception:
    _max_seconds = 60.0
try:
    _workers = int(_os.environ.get("SOLVER_WORKERS", "") or 8)
except Exception:
    _workers = 8
solver.parameters.num_search_workers = max(1, _workers)
