      entry('6A', 'mon', 2, 'Toán', 'Sơn'),
    ];
    const passReport = validateSchedule(passSchedule, [customDoubleSpec]);
    assert.equal(passReport.violations.length, 0);

    const failSchedule = [
      entry('6A', 'mon', 1, 'Toán', 'Sơn'),
      entry('6A', 'mon', 2, 'Toán', 'Sơn'),
      entry('6A', 'mon', 3, 'Toán', 'Sơn'),
