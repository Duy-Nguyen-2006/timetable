import { useState } from 'react'
import { Trash2, MapPin, User, Clock } from 'lucide-react'

function fmt(h, m) {
  const period = h >= 12 ? 'pm' : 'am'
  const hour = h === 0 ? 12 : h > 12 ? h - 12 : h
  return `${hour}:${String(m).padStart(2, '0')}${period}`
}

export default function SlotCard({ slot, subject, top, height, onDelete }) {
  const [hover, setHover] = useState(false)

  if (!subject) return null

  const isShort = height < 50

  return (
    <div
      className="absolute left-1 right-1 rounded-lg overflow-hidden cursor-pointer select-none z-10 shadow-sm transition-all hover:shadow-md hover:z-20"
      style={{
        top,
        height,
        backgroundColor: subject.color + '20',
        borderLeft: `3px solid ${subject.color}`,
      }}
      onMouseEnter={() => setHover(true)}
      onMouseLeave={() => setHover(false)}
    >
      <div className="p-1.5 h-full flex flex-col justify-between relative">
        <div className="min-w-0">
          <p
            className="text-xs font-bold truncate leading-tight"
            style={{ color: subject.color }}
          >
            {subject.name}
          </p>
          {!isShort && (
            <p className="text-xs text-gray-500 truncate flex items-center gap-0.5 mt-0.5">
              <Clock className="w-2.5 h-2.5 flex-shrink-0" />
              {fmt(slot.startHour, slot.startMin)} – {fmt(slot.endHour, slot.endMin)}
            </p>
          )}
          {!isShort && slot.room && (
            <p className="text-xs text-gray-500 truncate flex items-center gap-0.5">
              <MapPin className="w-2.5 h-2.5 flex-shrink-0" />
              {slot.room}
            </p>
          )}
          {!isShort && slot.teacher && (
            <p className="text-xs text-gray-500 truncate flex items-center gap-0.5">
              <User className="w-2.5 h-2.5 flex-shrink-0" />
              {slot.teacher}
            </p>
          )}
        </div>
      </div>

      {hover && (
        <button
          onClick={(e) => { e.stopPropagation(); onDelete() }}
          className="absolute top-1 right-1 bg-red-100 hover:bg-red-200 text-red-600 rounded p-0.5 transition-colors"
        >
          <Trash2 className="w-3 h-3" />
        </button>
      )}
    </div>
  )
}
