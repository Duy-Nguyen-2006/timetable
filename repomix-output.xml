import { useState } from 'react'
import SlotCard from './SlotCard'
import AddSlotModal from './AddSlotModal'
import { Plus } from 'lucide-react'

const DAYS = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday']
const HOURS = Array.from({ length: 15 }, (_, i) => i + 7) // 7am - 9pm

function timeToMinutes(h, m) { return h * 60 + m }
function minutesToPx(mins, pxPerHour = 60) { return (mins / 60) * pxPerHour }

export default function Timetable({ view, selectedDay, slots, subjects, onAddSlot, onDeleteSlot }) {
  const [addModal, setAddModal] = useState(null) // { day }

  const pxPerHour = 64
  const startHour = 7
  const totalHours = 15
  const totalHeight = totalHours * pxPerHour

  const days = view === 'week' ? DAYS : [DAYS[selectedDay - 1]]
  const dayNumbers = view === 'week' ? DAYS.map((_, i) => i + 1) : [selectedDay]

  const getSlotsForDay = (dayNum) =>
    slots.filter(s => s.day === dayNum)

  return (
    <div className="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
      {/* Day headers */}
      <div className={`grid border-b border-gray-200 bg-gray-50`} style={{ gridTemplateColumns: `64px repeat(${days.length}, 1fr)` }}>
        <div className="h-12 border-r border-gray-200" />
        {days.map((day, i) => (
          <div key={i} className="h-12 flex items-center justify-center border-r border-gray-200 last:border-r-0">
            <span className="text-sm font-semibold text-gray-700">{day}</span>
          </div>
        ))}
      </div>

      {/* Grid */}
      <div className="flex overflow-y-auto" style={{ maxHeight: 'calc(100vh - 200px)' }}>
        {/* Hour labels */}
        <div className="w-16 flex-shrink-0 border-r border-gray-200">
          {HOURS.map(h => (
            <div key={h} className="border-b border-gray-100 flex items-start justify-end pr-2 pt-1" style={{ height: pxPerHour }}>
              <span className="text-xs text-gray-400 font-medium">
                {h === 12 ? '12pm' : h < 12 ? `${h}am` : `${h - 12}pm`}
              </span>
            </div>
          ))}
        </div>

        {/* Day columns */}
        {dayNumbers.map((dayNum, colIdx) => {
          const daySlots = getSlotsForDay(dayNum)
          return (
            <div
              key={dayNum}
              className={`flex-1 relative border-r border-gray-200 last:border-r-0 ${colIdx % 2 === 0 ? 'bg-white' : 'bg-gray-50/30'}`}
              style={{ height: totalHeight }}
            >
              {/* Hour grid lines */}
              {HOURS.map(h => (
                <div
                  key={h}
                  className="absolute left-0 right-0 border-b border-gray-100"
                  style={{ top: (h - startHour) * pxPerHour, height: pxPerHour }}
                />
              ))}

              {/* Half hour lines */}
              {HOURS.map(h => (
                <div
                  key={`half-${h}`}
                  className="absolute left-0 right-0 border-b border-dashed border-gray-100"
                  style={{ top: (h - startHour) * pxPerHour + pxPerHour / 2 }}
                />
              ))}

              {/* Add button overlay */}
              <div
                className="absolute inset-0 group cursor-pointer"
                onClick={() => setAddModal({ day: dayNum })}
              >
                <div className="absolute inset-0 opacity-0 group-hover:opacity-100 bg-blue-50/40 flex items-center justify-center transition-opacity">
                  <div className="bg-blue-600 text-white rounded-full p-1.5 shadow-md">
                    <Plus className="w-4 h-4" />
                  </div>
                </div>
              </div>

              {/* Slots */}
              {daySlots.map(slot => {
                const subject = subjects.find(s => s.id === slot.subjectId)
                const top = minutesToPx(timeToMinutes(slot.startHour, slot.startMin) - timeToMinutes(startHour, 0), pxPerHour)
                const height = minutesToPx(
                  timeToMinutes(slot.endHour, slot.endMin) - timeToMinutes(slot.startHour, slot.startMin),
                  pxPerHour
                )
                return (
                  <SlotCard
                    key={slot.id}
                    slot={slot}
                    subject={subject}
                    top={top}
                    height={height}
                    onDelete={() => onDeleteSlot(slot.id)}
                  />
                )
              })}
            </div>
          )
        })}
      </div>

      {addModal && (
        <AddSlotModal
          day={addModal.day}
          subjects={subjects}
          onAdd={(slot) => {
            onAddSlot(slot)
            setAddModal(null)
          }}
          onClose={() => setAddModal(null)}
        />
      )}
    </div>
  )
}
</file>

