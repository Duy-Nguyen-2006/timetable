  it('teacher_max_consecutive passes when teacher has no scheduled entries', () => {
    const report = validateSchedule([entry('6A', 'mon', 1, 'Toán', 'Sơn')], [
      spec('teacher_max_consecutive_empty', 'teacher_max_consecutive', {
