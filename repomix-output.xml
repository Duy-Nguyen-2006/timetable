                        </>
                      ) : (
                        <>
                          <Sparkles size={20} />
                          Xếp thời khóa biểu
                        </>
                      )}
                    </button>
                  </div>

                  <div className="grid flex-1 gap-6 xl:grid-cols-[1.1fr_0.9fr]">
                    <div className="space-y-6">
                      <section className="overflow-hidden rounded-[8px] border border-[#212327] bg-[#191919] p-4  sm:p-5">
                      <div className="mb-5 flex items-center gap-3">
                        <span className="flex h-11 w-11 items-center justify-center rounded-[8px] border border-[#212327] bg-[#1a1c20] text-white">
                          <CalendarDays size={23} />
                        </span>
                        <div>
                          <h2 className="text-xl font-normal text-white">Bảng thời khóa biểu</h2>
                            <p className="text-sm text-[#a1a1aa]">Chỉ hiển thị những ô tiết đã chọn ở trang chỉnh thời khóa biểu.</p>
                        </div>
                      </div>

                      <div className="mb-4 grid gap-3 md:grid-cols-3">
                        {selectedSessionData.map((session) => {
                          const sessionTotal = selectedSpreadsheetDays.reduce(
                            (total, day) =>
                              total +
                              Array.from({ length: periods[session.id] ?? defaultPeriods[session.id] }, (_, index) => index + 1).filter(
                                (period) => !deletedPeriods[getCellKey(day.id, session.id, period)],
                              ).length,
                            0,
                          )

                          return (
                            <div key={session.id} className="rounded-full border border-[#212327] bg-[#111111] p-4">
                              <p className="text-xs font-normal uppercase tracking-[0.24em] text-white/80">{session.label}</p>
                              <p className="mt-2 text-2xl font-normal text-white">{sessionTotal}</p>
                              <p className="text-sm text-[#8b8d91]">ô tiết trong thời khóa biểu</p>
                            </div>
                          )
                        })}
                      </div>

                      <div className="overflow-auto rounded-full border border-[#212327] bg-[#191919] text-white ">
                        <table className="min-w-[900px] w-full border-separate border-spacing-0 table-fixed text-left text-sm sm:text-base">
                          <thead>
                            <tr>
                                <th className="sticky left-0 top-0 z-20 h-11 w-24 border-b border-r border-[#212327] bg-[#111111] px-3 text-xs font-normal uppercase tracking-[0.18em] text-white">
                                  Buổi
                                </th>
                                <th className="sticky left-24 top-0 z-20 h-11 w-16 border-b border-r border-[#212327] bg-[#111111] px-2 text-center text-xs font-normal uppercase tracking-[0.18em] text-white">
                                  Tiết
                                </th>
                                {selectedSpreadsheetDays.map((day) => (
                                <th key={day.id} className="sticky top-0 z-10 h-14 border-b border-r border-[#212327] bg-[#111111] px-3 text-center text-lg font-normal text-white">
                                  {day.tableLabel}
                                </th>
                              ))}
                            </tr>
                          </thead>
                          <tbody>
                              {summaryTimetableRows.map((row) => (
                                <tr key={row.id} className="h-12">
                                  {row.firstInSession ? (
                                    <td rowSpan={row.sessionPeriodCount} className="sticky left-0 z-10 w-24 border-b border-r border-[#212327] bg-[#111111] px-3 text-center align-middle">
                                      <span className="text-sm font-normal text-white">{row.sessionLabel}</span>
                                    </td>
                                  ) : null}
                                  <td className="sticky left-24 z-10 w-16 border-b border-r border-[#212327] bg-[#111111] px-2 text-center align-middle">
                                    <span className="text-sm font-normal text-white">{row.period}</span>
                                  </td>
                                  {selectedSpreadsheetDays.map((day) => {
                                  const cellKey = getCellKey(day.id, row.sessionId, row.period)
                                  const isDeleted = deletedPeriods[cellKey]

                                    return (
                                      <td key={cellKey} className="border-b border-r border-[#212327] p-2">
                                        {!isDeleted ? (
                                            <div className="flex h-8 w-full items-center justify-center rounded-[8px] border border-[#212327] bg-[#1a1c20] px-2 text-sm font-normal text-white">

                                            {row.period}
                                          </div>
                                        ) : null}
                                      </td>
                                    )
                                })}
                              </tr>
                            ))}
                          </tbody>
                          </table>
                        </div>
                      </section>

                      <section className="rounded-[8px] border border-[#212327] bg-[#1a1c20] p-5">
                        <div className="mb-5 flex items-center gap-3">
                          <span className="flex h-11 w-11 items-center justify-center rounded-[8px] border border-[#212327] bg-[#111111] text-white">
                            <ClipboardList size={23} />
                          </span>
                          <div>
                            <h2 className="text-xl font-normal text-white">Ràng buộc xếp lịch</h2>
                            <p className="text-sm text-[#a1a1aa]">Bắt buộc và Nên có</p>
                          </div>
                        </div>

                        <div className="space-y-3">
                            {constraintList.length ? (
                              sortedConstraintList.map((constraint) => {
                                const constraintType = constraintTypes[constraint.type] ?? constraintTypes.required

                                return (
                                    <div key={constraint.id} className={`rounded-[8px] border p-3 ${constraint.type === 'required' ? 'border-white/40 bg-[#1a1c20]' : 'border-[#3a3d43] bg-[#171717]'}`}>

                                    <div className="mb-2 flex flex-wrap items-center justify-between gap-2">
                                      <span className={`inline-flex items-center gap-2 rounded-full border-2 px-3 py-1 text-xs font-normal ${constraintType.badgeClass}`}>
                                        <Circle className={constraintType.iconClass} size={12} fill="currentColor" />
                                        {constraintType.label}
                                      </span>
                                  </div>
                                  <p className="rounded-[8px] border border-[#212327] bg-[#111111] p-3 text-sm font-normal leading-6 text-white">
                                    {constraint.text}
                                  </p>
                                </div>
                              )
                            })
                          ) : (
                            <div className="rounded-full border border-[#212327] bg-[#111111] p-5 text-sm leading-6 text-[#b0b3b8]">
                              Chưa có ràng buộc xếp lịch nào.
                            </div>
                          )}
                        </div>
                      </section>
                    </div>

                      <aside className="rounded-[8px] border border-[#212327] bg-[#1a1c20] p-5">
                      <div className="mb-5 flex items-center gap-3">
                        <span className="flex h-11 w-11 items-center justify-center rounded-[8px] border border-[#212327] bg-[#111111] text-white">
                          <BookOpen size={23} />
                        </span>
                        <div>
                          <h2 className="text-xl font-normal text-white">Phân công chuyên môn</h2>
                          <p className="text-sm text-[#a1a1aa]">Tổng hợp giáo viên - môn - lớp - số tiết/tuần</p>
                        </div>
                      </div>

                      <div className="space-y-3">
                        {assignmentList.length ? (
                          sortedAssignmentList.map((assignment, index) => {
                            const teacherColor = teacherColorMap[assignment.teacher] ?? teacherColors[0]

                            return (
                              <div key={assignment.key} className="rounded-full border-2 p-3" style={{ borderColor: teacherColor.border, backgroundColor: teacherColor.bg }}>
                                <div className="mb-3 flex items-center justify-between gap-3">
                                  <p className="text-xs font-normal uppercase tracking-[0.18em]" style={{ color: teacherColor.text }}>Phân công {index + 1}</p>
                                  <span className="rounded-full border-2 px-2.5 py-1 text-xs font-normal" style={{ borderColor: teacherColor.text, color: teacherColor.text, backgroundColor: teacherColor.softText }}>
                                    {assignment.teacher}
                                  </span>
                                </div>
                                <div className="grid gap-2 sm:grid-cols-2">
                                  <div className="rounded-[8px] border-2 bg-[#111111] p-3" style={{ borderColor: teacherColor.text }}>
                                    <p className="text-[10px] font-normal uppercase tracking-[0.18em]" style={{ color: teacherColor.softText }}>Giáo viên</p>
                                    <p className="mt-1 truncate text-base font-normal" style={{ color: teacherColor.softText }}>{assignment.teacher}</p>
                                  </div>
                                  <div className="rounded-[8px] border-2 border-[#212327] bg-[#111111] p-3">
                                    <p className="text-[10px] font-normal uppercase tracking-[0.18em] text-white">Môn học</p>
                                    <p className="mt-1 truncate text-base font-normal text-white">{assignment.subject}</p>
                                  </div>
                                  <div className="rounded-[8px] border-2 border-[#212327] bg-[#111111] p-3">
                                    <p className="text-[10px] font-normal uppercase tracking-[0.18em] text-white">Lớp</p>
                                    <p className="mt-1 truncate text-base font-normal text-white">{assignment.className}</p>
                                  </div>
                                  <div className="rounded-[8px] border-2 border-[#212327] bg-[#111111] p-3">
                                    <p className="text-[10px] font-normal uppercase tracking-[0.18em] text-white">Số tiết/tuần</p>
                                    <p className="mt-1 truncate text-base font-normal text-white">{assignment.weeklyPeriods}</p>
                                  </div>
                                </div>
                              </div>
                            )
                          })
                          ) : (
                            <div className="rounded-full border border-[#212327] bg-[#111111] p-5 text-sm leading-6 text-[#b0b3b8]">
                              Chưa có phân công chuyên môn nào.
                            </div>
                          )}
                        </div>

                      </aside>
                    </div>

                    {(aiLoading || aiResult || aiError) && (
                      <section className="mt-6 overflow-hidden rounded-[8px] border border-[#212327] bg-[#191919] p-5">
                        <div className="mb-5 flex items-center gap-3">
                          <span className="flex h-11 w-11 items-center justify-center rounded-[8px] border border-[#212327] bg-[#1a1c20] text-white">
                            <Sparkles size={23} />
                          </span>
                          <div>
                            <h2 className="text-xl font-normal text-white">Kết quả xếp thời khóa biểu</h2>
                            <p className="text-sm text-[#a1a1aa]">Được tạo tự động bởi AI</p>
                          </div>
                        </div>

                        {aiLoading && (
                          <div className="flex items-center justify-center gap-3 rounded-[8px] border border-[#212327] bg-[#111111] py-16 text-white">
                            <Loader2 size={28} className="animate-spin" />
                            <span className="text-base font-normal">AI đang xếp thời khóa biểu, vui lòng chờ...</span>
                          </div>
                        )}

                        {aiError && !aiLoading && (
                          <div className="rounded-[8px] border border-white/40 bg-[#1a1c20] p-5">
                            <p className="font-normal text-white">Lỗi xảy ra:</p>
                            <p className="mt-2 text-sm text-[#dadbdf]">{aiError}</p>
                            <button
                              type="button"
                              onClick={handleGenerate}
                              className="mt-4 inline-flex items-center gap-2 rounded-[8px] border border-[#212327] bg-[#111111] px-4 py-2 text-sm font-normal text-white transition hover:border-white/40 hover:bg-[#222428]"
                            >
                              <RotateCcw size={16} />
                              Thử lại
                            </button>
                          </div>
                        )}

                        {aiResult && !aiLoading && (
                          <div className="prose prose-invert prose-sm max-w-none rounded-[8px] border border-[#212327] bg-[#111111] p-5 text-white [&_table]:w-full [&_table]:border-collapse [&_td]:border [&_td]:border-[#212327] [&_td]:p-2 [&_th]:border [&_th]:border-[#212327] [&_th]:bg-[#1a1c20] [&_th]:p-2 [&_th]:font-normal [&_h1]:text-white [&_h2]:text-white [&_h3]:text-white [&_strong]:text-white">
                            <AiMarkdown content={aiResult} />
                          </div>
                        )}
                      </section>
                    )}


                </section>
              )}
          </main>


  )
}
