            reifiedNeeded: [],
            objective: 'none',
            templatesUsed: [],
            risks: [],
          }),
          usage: { total_tokens: 1 },
        });
      }

      if (systemPrompt === 'coder') {
        coderCalls += 1;
        return Response.json({
          ok: true,
          content: JSON.stringify({
            plan_summary: 'bad runtime code',
            constraint_code: "# c1\nraise RuntimeError('bad')",
            covered_constraint_ids: [],
            assumptions: [],
          }),
