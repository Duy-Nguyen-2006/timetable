function formatDuration(ms: number) {
  if (ms < 1000) return `${ms}ms`
  return `${(ms / 1000).toFixed(ms >= 10_000 ? 0 : 1)}s`
}

function formatNullableNumber(value: number | null | undefined) {
  if (value === null || value === undefined) return '—'
