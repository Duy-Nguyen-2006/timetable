                day_counts[s["day"]] += 1
        for d, count in day_counts.items():
            assert count <= 1, f"T3 has {count} periods on {d}"

    def test_no_double_subject_day(self):
        result = _run_skeleton(_make_dataset_hard_constraints())
        from collections import Counter
        for d in ["mon", "tue", "wed"]:
