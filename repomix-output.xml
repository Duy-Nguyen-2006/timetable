    if (url.endsWith('/api/ai/chat')) {
      const body = JSON.parse(String(init?.body ?? '{}')) as {
        messages?: Array<{ role: string; content: string }>;
      };
      const systemPrompt = body.messages?.[0]?.content;

      if (systemPrompt === 'translator') {
        return Response.json({
