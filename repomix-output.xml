import { useState } from 'react'
import { X, Clock, MapPin, User, BookOpen } from 'lucide-react'

const DAYS = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday']

export default function AddSlotModal({ day, subjects, onAdd, onClose }) {
  const [form, setForm] = useState({
    day,
    subjectId: subjects[0]?.id || '',
    startHour: 9,
    startMin: 0,
    endHour: 10,
    endMin: 30,
    room: '',
    teacher: '',
  })

  const set = (key, val) => setForm(f => ({ ...f, [key]: val }))

  const handleSubmit = (e) => {
    e.preventDefault()
    if (!form.subjectId) return
    if (
      form.startHour > form.endHour ||
      (form.startHour === form.endHour && form.startMin >= form.endMin)
    ) {
      alert('End time must be after start time.')
      return
    }
    onAdd({
      ...form,
      startHour: Number(form.startHour),
      startMin: Number(form.startMin),
      endHour: Number(form.endHour),
      endMin: Number(form.endMin),
      day: Number(form.day),
    })
  }

  const timeOptions = []
  for (let h = 7; h <= 21; h++) {
    for (const m of [0, 15, 30, 45]) {
      timeOptions.push({ h, m, label: `${h === 0 ? 12 : h > 12 ? h - 12 : h}:${String(m).padStart(2, '0')} ${h >= 12 ? 'pm' : 'am'}` })
    }
  }

  return (
    <div className="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center z-50 p-4" onClick={onClose}>
      <div
        className="bg-white rounded-2xl shadow-2xl w-full max-w-md"
        onClick={e => e.stopPropagation()}
      >
        <div className="flex items-center justify-between p-5 border-b border-gray-100">
          <h2 className="text-lg font-bold text-gray-900">Add Class</h2>
          <button onClick={onClose} className="text-gray-400 hover:text-gray-600 transition-colors">
            <X className="w-5 h-5" />
          </button>
        </div>

        <form onSubmit={handleSubmit} className="p-5 space-y-4">
          {/* Day */}
          <div>
            <label className="text-sm font-medium text-gray-700 flex items-center gap-1.5 mb-1.5">
              Day
            </label>
            <select
              value={form.day}
              onChange={e => set('day', Number(e.target.value))}
              className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
            >
              {DAYS.map((d, i) => (
                <option key={i} value={i + 1}>{d}</option>
              ))}
            </select>
          </div>

          {/* Subject */}
          <div>
            <label className="text-sm font-medium text-gray-700 flex items-center gap-1.5 mb-1.5">
              <BookOpen className="w-4 h-4 text-gray-500" />
              Subject
            </label>
            {subjects.length === 0 ? (
              <p className="text-sm text-red-500">Add a subject first from the sidebar.</p>
            ) : (
              <select
                value={form.subjectId}
                onChange={e => set('subjectId', e.target.value)}
                className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
              >
                {subjects.map(s => (
                  <option key={s.id} value={s.id}>{s.name}</option>
                ))}
              </select>
            )}
          </div>

          {/* Time */}
          <div className="grid grid-cols-2 gap-3">
            <div>
              <label className="text-sm font-medium text-gray-700 flex items-center gap-1.5 mb-1.5">
                <Clock className="w-4 h-4 text-gray-500" />
                Start Time
              </label>
              <select
                value={`${form.startHour}:${form.startMin}`}
                onChange={e => {
                  const [h, m] = e.target.value.split(':').map(Number)
                  set('startHour', h); set('startMin', m)
                }}
                className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
              >
                {timeOptions.map(t => (
                  <option key={`${t.h}:${t.m}`} value={`${t.h}:${t.m}`}>{t.label}</option>
                ))}
              </select>
            </div>
            <div>
              <label className="text-sm font-medium text-gray-700 flex items-center gap-1.5 mb-1.5">
                <Clock className="w-4 h-4 text-gray-500" />
                End Time
              </label>
              <select
                value={`${form.endHour}:${form.endMin}`}
                onChange={e => {
                  const [h, m] = e.target.value.split(':').map(Number)
                  set('endHour', h); set('endMin', m)
                }}
                className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
              >
                {timeOptions.map(t => (
                  <option key={`${t.h}:${t.m}`} value={`${t.h}:${t.m}`}>{t.label}</option>
                ))}
              </select>
            </div>
          </div>

          {/* Room */}
          <div>
            <label className="text-sm font-medium text-gray-700 flex items-center gap-1.5 mb-1.5">
              <MapPin className="w-4 h-4 text-gray-500" />
              Room <span className="text-gray-400 font-normal">(optional)</span>
            </label>
            <input
              type="text"
              value={form.room}
              onChange={e => set('room', e.target.value)}
              placeholder="e.g. Room 101"
              className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
            />
          </div>

          {/* Teacher */}
          <div>
            <label className="text-sm font-medium text-gray-700 flex items-center gap-1.5 mb-1.5">
              <User className="w-4 h-4 text-gray-500" />
              Teacher <span className="text-gray-400 font-normal">(optional)</span>
            </label>
            <input
              type="text"
              value={form.teacher}
              onChange={e => set('teacher', e.target.value)}
              placeholder="e.g. Mr. Smith"
              className="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
            />
          </div>

          <div className="flex gap-3 pt-2">
            <button
              type="button"
              onClick={onClose}
              className="flex-1 py-2.5 border border-gray-300 text-gray-700 rounded-xl font-medium hover:bg-gray-50 transition-colors text-sm"
            >
              Cancel
            </button>
            <button
              type="submit"
              disabled={!form.subjectId}
              className="flex-1 py-2.5 bg-blue-600 text-white rounded-xl font-medium hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed transition-colors text-sm"
            >
              Add Class
            </button>
          </div>
        </form>
      </div>
    </div>
  )
}
