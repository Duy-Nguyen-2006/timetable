}

export default function App({ onBackToLanding, quickDatasetText }: TimetableAppProps) {
  const [page, setPage] = useState('select')
  const [selectedDays, setSelectedDays] = useState(['monday', 'tuesday', 'wednesday', 'thursday', 'friday'])
