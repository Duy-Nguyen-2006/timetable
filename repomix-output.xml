        assert result["status"] in ("optimal", "feasible")

    def test_block_slot(self):
        result = _run_skeleton(_make_dataset_hard_constraints())
        for s in result["schedule"]:
            if s["teacher"] == "T1":
                assert not (s["day"] == "mon" and s["period"] == 1)

    def test_max_per_day(self):
