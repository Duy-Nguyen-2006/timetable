# Dockerfile for AI Agent Code Sandbox
# Purpose: Run untrusted Python code (generated by LLM) in an isolated environment.
#
# Security features:
# - Non-root user
# - Minimal attack surface
# - No network access at runtime (enforced by --network=none when running)
# - Read-only root filesystem (enforced at runtime)
# - Resource limits (enforced at runtime)

FROM python:3.11-slim

# Prevent interactive prompts during build
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Install only what's strictly necessary + ortools dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        && rm -rf /var/lib/apt/lists/*

# Install Python dependencies needed by the solver
# Pin versions for reproducibility and security
RUN pip install --no-cache-dir \
        ortools==9.11.4210 \
        python-dotenv==1.0.1

# Create non-root user
RUN groupadd -r sandbox && useradd -r -g sandbox -u 10001 sandbox \
    && mkdir -p /workspace \
    && chown -R sandbox:sandbox /workspace

# Set working directory
WORKDIR /workspace

# Drop to non-root user
USER sandbox

# Default command (overridden at runtime)
CMD ["python", "-c", "print('Sandbox ready')"]