            {"id": "a2", "class": "6B", "subject": "Toán", "teacher": "Sơn", "weeklyPeriods": 4},
        ],
        "constraints": [
            {
                "id": "max_4_days",
                "severity": "hard",
                "kind": "custom_dsl",
                "original": "Mỗi GV dạy tối đa 4 buổi/tuần",
