test('rule parser: Lớp 10A không có tiết trống → class_no_gaps', () => {
  const input: AgentInputPayload = {
    ...sampleInput,
    assignments: [
      { id: 'asg_x', teacher: { id: 't9', label: 'An' }, subject: { id: 's1', label: 'Toán' }, class: { id: 'c9', label: '10A' }, weeklyPeriods: 4 },
