  );
});

test('M8.2: isIRFirstAuthoritative reflects mode', () => {
  setParserMode('legacy');
  assert.equal(isIRFirstAuthoritative(), false);
  setParserMode('shadow');
  assert.equal(isIRFirstAuthoritative(), false);
  setParserMode('ir_first');
  assert.equal(isIRFirstAuthoritative(), true);
