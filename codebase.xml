name: Reusable Windows Build

on:
  workflow_call:
    inputs:
      artifact_name:
        description: "Name for the uploaded installer artifact"
        type: string
        default: windows-installer
      publish_release:
        description: "Publish release assets to a GitHub release (only true on tag pushes)"
        type: boolean
        default: false

jobs:
  build:
    runs-on: windows-latest
    timeout-minutes: 45
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Validate electron main syntax (fail fast)
        shell: pwsh
        run: node --check electron/main.mjs

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: npm

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"
          cache: pip
          cache-dependency-path: requirements.txt

      - name: Install Python deps (ortools + pyinstaller)
        shell: pwsh
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt pyinstaller

      - name: Install JS deps
        shell: pwsh
        run: npm ci

      - name: Prune transient npm rename dirs in node_modules
        shell: pwsh
        run: node scripts/prune-transient.mjs

      - name: Cache Python executor binary
        id: cache-executor
        uses: actions/cache@v4
        with:
          path: python-dist
          key: pyexec-${{ runner.os }}-${{ hashFiles('requirements.txt', 'python/code_executor.py', 'python/validator_engine.py', 'sandbox/**', 'scripts/build_executor.mjs') }}

      - name: Build Python executor (code_executor.exe)
        if: steps.cache-executor.outputs.cache-hit != 'true'
        shell: pwsh
        run: npm run build:executor:win

      - name: Verify code_executor.exe present
        shell: pwsh
        run: |
          $bin = "python-dist/code_executor.exe"
          if (-not (Test-Path $bin)) {
            Write-Error "Missing $bin"
            exit 1
          }
          $size = (Get-Item $bin).Length
          Write-Host "code_executor.exe size: $size bytes"
          if ($size -lt 5000000) {
            Write-Error "code_executor.exe smaller than expected; PyInstaller likely failed."
            exit 1
          }

      - name: Run Electron tests
        shell: pwsh
        run: npm run test:electron

      - name: Build Next app
        shell: pwsh
        run: npm run build

      - name: Strip nested .next/node_modules from standalone
        shell: pwsh
        run: |
          $junk = ".next/standalone/.next/node_modules"
          if (Test-Path $junk) {
            Write-Host "Removing $junk"
            Remove-Item -LiteralPath $junk -Recurse -Force
          }
          node scripts/prune-transient.mjs

      - name: Package Windows installer (electron-builder)
        shell: pwsh
        run: npm run package:win

      - name: Inspect release artifacts
        shell: pwsh
        run: |
          if (-not (Test-Path "release")) {
            Write-Error "release/ directory missing after package:win"
            exit 1
          }
          Get-ChildItem release -Recurse | Select-Object FullName, Length | Format-Table -AutoSize
          $exe = Get-ChildItem release -Filter "*.exe" -Recurse | Select-Object -First 1
          if (-not $exe) {
            Write-Error "No .exe artifact found in release/"
            exit 1
          }
          Write-Host "Primary installer: $($exe.FullName) ($([math]::Round($exe.Length/1MB,2)) MB)"

      - name: Upload installer artifact
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: ${{ inputs.artifact_name }}
          path: |
            release/*.exe
            release/*.blockmap
            release/latest*.yml
          if-no-files-found: warn

      - name: Publish GitHub release assets
        if: ${{ inputs.publish_release }}
        uses: softprops/action-gh-release@v2
        with:
          files: release/*
</file>

