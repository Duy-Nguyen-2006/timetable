  assert.ok(onlyOpt?.specDraft, 'only option must carry specDraft');
  assert.equal(requireOpt!.specDraft!.kind, 'teacher_required_period');
  assert.equal(onlyOpt!.specDraft!.kind, 'teacher_allowed_periods');
