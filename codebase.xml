    assert result["status"] in ("optimal", "feasible"), result

    # Verify: 6A's Toán periods have no 3-in-a-row streak on any day
    toan_by_day: dict[str, list[int]] = {}
    for e in result["schedule"]:
        if e["class"] == "6A" and e["subject"] == "Toán":
