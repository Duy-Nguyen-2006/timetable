  assert.equal(result.interpretationCard?.scopeVi, 'Áp dụng trong thứ 6');
  assert.equal(result.interpretationCard?.thenAtomsVi.length, 1);
  assert.equal(result.interpretationCard?.notesVi.length, 1);
