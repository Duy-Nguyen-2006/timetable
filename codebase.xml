def test_ir_subject_max_consecutive_6a() -> None:
    """6A cannot have 3 consecutive Toán periods on any day."""
    payload = {
        "classes": ["6A"],
        "days": ["mon", "tue", "wed"],
        "periods": [1, 2, 3, 4],
        "periodsByDay": {"mon": [1, 2, 3, 4], "tue": [1, 2, 3, 4], "wed": [1, 2, 3, 4]},
