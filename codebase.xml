  assert.equal(gate.status, 'unambiguous');
});

test('evaluateAmbiguity flags same-family candidates as ambiguous', () => {
  const candidates = [
    {
      kind: 'teacher_block_day' as any,
      scope: 'teacher' as any,
      embedding: null,
      triggers: [],
      synonyms: [],
