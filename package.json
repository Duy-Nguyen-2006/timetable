{
  "name": "timetable",
  "version": "0.2.0",
  "private": true,
  "description": "AI-assisted timetable generator (Coder + Reviewer loop, Python sandbox + execution, OR-Tools ready)",
  "scripts": {
    "presync:skeleton": "node scripts/sync_solver_template.mjs",
    "sync:prompts": "node scripts/sync_prompts.mjs",
    "predev": "npm run sync:prompts && npm run presync:skeleton",
    "dev": "NODE_OPTIONS=--disable-warning=DEP0205 next dev",
    "prebuild": "npm run sync:prompts && npm run presync:skeleton",
    "build": "NODE_OPTIONS=--disable-warning=DEP0205 next build && node scripts/post-build.mjs",
    "prestart": "npm run presync:skeleton",
    "start": "next start",
    "pretest": "npm run presync:skeleton",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "test:grep": "sh -c 'tsx --test \"src/**/*$1*.test.ts\"' --",
    "test:prompt": "tsx scripts/validate_coder_prompt_models.ts",
    "provider:smoke": "tsx scripts/provider_smoke_test.ts",
    "lint": "eslint .",
    "electron": "electron .",
    "package:win": "electron-builder --win --publish never",
    "dist:linux": "npm run build && electron-builder --linux AppImage --publish never"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@reactuses/core": "^6.0.5",
    "@tanstack/react-query": "^5.82.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "next": "^16.1.1",
    "next-themes": "^0.4.6",
    "openai": "^6.39.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.3",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "zod": "^4.0.2",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^37.10.3",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.tackstudio.timetable",
    "productName": "Tack Timetable",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "python-dist/code_executor",
        "to": "python"
      },
      {
        "from": "python/code_executor.py",
        "to": "python-src/code_executor.py"
      },
      {
        "from": "python/code_executor",
        "to": "python-src/code_executor",
        "filter": [
          "**/*",
          "!__pycache__/**/*"
        ]
      }
    ],
    "asarUnpack": [
      "**/*.node",
      ".next/standalone/**/*",
      ".next/static/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "Tack-Timetable-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "Tack-Timetable-${version}-${arch}.${ext}",
      "category": "Education"
    }
  }
}
