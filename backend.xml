/**
 * python-bridge.ts
 *
 * High-level bridge between the timetable solver and the Python execution host.
 * The only allowed solve path is a fixed solver skeleton. AI-generated Python
 * code is no longer accepted by the web fallback.
 */

import type { ExecutionResult } from './types';

export interface PythonBridgeOptions {
  timeoutMs?: number;
  solverWorkers?: number;
  /** Optional fixed seed for solver determinism. */
  solverSeed?: number;
  signal?: AbortSignal;
}

/**
 * Execute the fixed Python solver skeleton with the prepared input payload.
 *
 * Electron still receives `code` because the desktop preload executes the
 * bundled fixed skeleton locally. The web fallback deliberately does not send
 * code to the server; /api/solver/execute loads the trusted skeleton itself.
 */
export async function executeSolverCode(
  code: string,
  input: unknown,
  options: PythonBridgeOptions = {}
): Promise<ExecutionResult> {
  const timeout = options.timeoutMs ?? 360_000;

  if (typeof window !== 'undefined' && window.electron?.python?.executeCode) {
    return (window.electron.python.executeCode as (
      code: string,
      input: unknown,
      timeout: number,
      workers?: number,
      seed?: number
    ) => Promise<ExecutionResult>)(
      code,
      input,
      timeout,
      options.solverWorkers,
      options.solverSeed
    );
  }

  if (typeof window !== 'undefined') {
    const response = await fetch('/api/solver/execute', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      signal: options.signal,
      body: JSON.stringify({
        input,
        timeoutMs: timeout,
        solverWorkers: options.solverWorkers,
        solverSeed: options.solverSeed,
      }),
    });

    const payload = await response.json().catch(() => null);

    if (!response.ok || !payload?.ok || !payload?.result) {
      throw new Error(
        payload?.error || `[python-bridge] Server executor failed with HTTP ${response.status}`
      );
    }

    return payload.result as ExecutionResult;
  }

  throw new Error(
    '[python-bridge] Python executor IPC is not available. Run inside Electron or use /api/solver/execute in a browser runtime.'
  );
}

/**
 * Backward-compatible alias. New code must call executeSolverCode.
 */
export const executeGeneratedCode = executeSolverCode;
