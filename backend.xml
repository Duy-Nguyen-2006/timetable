<file path="src/features/timetable/ai/constraint-clarification.ts">
import type { ConstraintClarificationQuestion } from './constraint-review-types';

/** Build user-facing clarification questions when parser/LLM only partially understood a constraint. */
export function buildClarificationQuestions(original: string): ConstraintClarificationQuestion[] {
  const raw = original.normalize('NFC').replace(/\s+/g, ' ').trim().toLowerCase();
  const questions: ConstraintClarificationQuestion[] = [];

  const pushUnique = (question: ConstraintClarificationQuestion) => {
    if (!questions.some((existing) => existing.id === question.id || existing.prompt === question.prompt)) {
      questions.push(question);
    }
  };

  const periodCountMatch = raw.match(/(\d+)\s*(tiết|tiet)/u);
  const periodCount = periodCountMatch?.[1] ?? '';

  const mentionsTeacher = /(giáo\s*viên|giao\s*vien|\bgv\b|thầy|thay|cô|co)/u.test(raw);
  const mentionsClass = /(lớp|lop)/u.test(raw);
  const mentionsLimit = /(không|khong|tối\s*đa|toi\s*da|quá|qua|nhiều\s*nhất|nhieu\s*nhat|hơn|hon)/u.test(raw);
  const mentionsPeriodCount = Boolean(periodCountMatch);

  // Example: "1 giáo viên không dạy 1 lớp quá 2 tiết".
  // This is ambiguous without a time scope: per week, per day, or per session.
  if (mentionsTeacher && mentionsClass && mentionsLimit && mentionsPeriodCount) {
    pushUnique({
      id: 'teacher_class_period_limit_scope',
      prompt: periodCount
        ? `Bạn muốn giới hạn “một giáo viên dạy một lớp tối đa ${periodCount} tiết” theo khoảng nào?`
        : 'Bạn muốn giới hạn số tiết một giáo viên dạy một lớp theo khoảng nào?',
      options: [
        periodCount
          ? `Mỗi tuần: một giáo viên dạy một lớp tối đa ${periodCount} tiết/tuần`
          : 'Mỗi tuần',
        periodCount
          ? `Mỗi ngày: một giáo viên dạy một lớp tối đa ${periodCount} tiết/ngày`
          : 'Mỗi ngày',
        periodCount
          ? `Mỗi buổi sáng/chiều: một giáo viên dạy một lớp tối đa ${periodCount} tiết/buổi`
          : 'Mỗi buổi sáng/chiều',
        'Khác — tôi sẽ viết rõ hơn',
      ],
    });
  }

  const mentionsHeavy =
    /môn\s*nặng|mon\s*nang|tiết\s*nặng|tiet\s*nang|môn\s*chính|mon\s*chinh/u.test(raw);
  const mentionsSameDay = /(cùng|cung).*(ngày|ngay)/u.test(raw);
  const mentionsSubject = /(môn|mon|tiết|tiet)/u.test(raw);

  const mentionsSession = /(buổi|buoi|sáng|sang|chiều|chieu)/u.test(raw);
  const mentionsSpread = /(dồn|don|xen\s*kẽ|xen\s*ke|không\s*chỉ|khong\s*chi)/u.test(raw);

  // Detect "không ... quá N tiết ... trong 1 buổi".
  // User may mean limit per session or per day, so ask before encoding.
  const mentionsSessionLimit = /(không|khong|tối\s*đa|toi\s*da|quá|qua|nhiều\s*nhất|nhieu\s*nhat|hơn|hon)/u.test(raw);
  if (
    mentionsSessionLimit &&
    mentionsPeriodCount &&
    mentionsSession &&
    questions.length === 0
  ) {
    pushUnique({
      id: 'session_subject_period_limit',
      prompt: periodCount
        ? `Ràng buộc «tối đa ${periodCount} tiết cùng môn trong một buổi» — bạn muốn giới hạn theo buổi (sáng/chiều) hay theo cả ngày?`
        : 'Ràng buộc nói «trong một buổi» — bạn muốn giới hạn theo buổi hay theo cả ngày?',
      options: [
        'Theo buổi (sáng/chiều) — mỗi buổi không quá N tiết cùng môn',
        'Theo cả ngày — không quá N tiết cùng môn trong ngày',
        'Cả hai — buổi là giới hạn trên, ngày là giới hạn cứng',
        'Khác (dùng «Sửa cách hiểu» để mô tả thêm)',
      ],
    });
  }

  if (mentionsHeavy && mentionsSession && mentionsSpread) {
    pushUnique({
      id: 'heavy_same_session_scope',
      prompt: '«Môn nặng trong một buổi không dồn vào một lớp» — bạn muốn giới hạn gì?',
      options: [
        'Mỗi lớp, mỗi buổi (sáng hoặc chiều): tối đa 2 môn nặng (Toán, Văn, Anh, …), còn lại xen kẽ môn khác',
        'Mỗi lớp, mỗi buổi: tối đa 1 môn nặng',
        'Khác (dùng «Sửa cách hiểu»)',
      ],
    });
  }

  if (mentionsHeavy && mentionsSameDay) {
    pushUnique({
      id: 'heavy_same_day_scope',
      prompt:
        '«Tiết/môn nặng không xếp cùng một ngày» — bạn muốn nói điều gì?',
      options: [
        'Cùng một lớp, cùng một ngày: không xếp hai môn nặng (Toán, Văn, …) vào cùng ngày đó',
        'Cùng một lớp, khác ngày: mỗi ngày chỉ nên có tối đa một môn nặng',
        'Toàn trường: mỗi lớp mỗi ngày không quá N môn nặng',
      ],
    });
  } else if (mentionsSameDay && mentionsClass) {
    pushUnique({
      id: 'same_day_class_scope',
      prompt: '«Không cùng một ngày ở cùng một lớp» — bạn muốn giới hạn gì?',
      options: [
        'Không xếp hai môn khác nhau vào cùng một ngày trong cùng một lớp',
        'Không xếp cùng một môn hai lần trong cùng một ngày (tối đa 1 lần/ngày)',
        'Khác (sẽ mô tả thêm trong «Sửa cách hiểu»)',
      ],
    });
  } else if (mentionsSameDay && !mentionsClass) {
    pushUnique({
      id: 'same_day_without_class',
      prompt: 'Ràng buộc nói «cùng ngày» nhưng chưa rõ áp dụng cho lớp nào?',
      options: [
        'Áp dụng cho từng lớp: mỗi lớp mỗi ngày tuân theo ràng buộc',
        'Áp dụng cho toàn trường (mọi lớp)',
      ],
    });
  }

  if (mentionsSubject && /(không\s*nên|khong\s*nen|ưu\s*tiên|uu\s*tien)/u.test(raw) && questions.length === 0) {
    pushUnique({
      id: 'soft_vs_hard',
      prompt: 'Đây là ràng buộc bắt buộc hay chỉ ưu tiên (nên có)?',
      options: ['Chỉ ưu tiên (nên có)', 'Bắt buộc'],
    });
  }

  if (questions.length === 0) {
    pushUnique({
      id: 'general_meaning',
      prompt: 'Hệ thống chưa chắc cách hiểu câu này. Bạn muốn nhấn mạnh điều gì nhất?',
      options: [
        'Giới hạn theo từng lớp, từng ngày',
        'Giới hạn theo giáo viên / môn học',
        'Chỉ là gợi ý ưu tiên, không bắt buộc',
      ],
    });
  }

  return questions;
}
