{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "parsableStyle": false,
    "compress": false,
    "fileSummary": true,
    "directoryStructure": true,
    "files": true,
    "removeComments": false,
    "removeEmptyLines": false,
    "topFilesLength": 20,
    "tokenCountTree": 1000,
    "showLineNumbers": false,
    "truncateBase64": true,
    "copyToClipboard": false,
    "git": {
      "sortByChanges": true,
      "sortByChangesMaxCommits": 100,
      "includeDiffs": false,
      "includeLogs": false,
      "includeLogsCount": 50
    }
  },
  "include": [
    "src/**/*",
    "electron/**/*",
    "python/**/*",
    "sandbox/**/*",
    "prompts/**/*",
    "scripts/**/*",
    "package.json",
    "package-lock.json",
    "requirements.txt",
    "next.config.ts",
    "tsconfig.json",
    "eslint.config.mjs",
    "postcss.config.mjs",
    "tailwind.config.ts",
    "components.json",
    "Caddyfile",
    "datasets.txt",
    ".gitignore"
  ],
  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "repomix-output.xml",
      "*.tsbuildinfo",
      "node_modules/**",
      ".next/**",
      ".git/**",
      ".github/**",
      ".claude/**",
      ".ai_results/**",
      ".gitnexus/**",
      ".pytest_cache/**",
      "**/__pycache__/**",
      "**/*.pyc",
      "harness.db",
      "harness.db-*",
      "droid-wiki/**",
      "droid-wiki-page-plan.json",
      "droid-wiki-survey-context.md",
      "docs/**",
      "AGENTS.md",
      "CLAUDE.md",
      "README.md",
      "SPEC.md",
      "scripts/bin/**",
      "public/prompts/**",
      "public/templates/**",
      "public/**/*.png",
      "public/**/*.jpg",
      "public/**/*.jpeg",
      "public/**/*.gif",
      "public/**/*.webp",
      "public/**/*.ico",
      "public/**/*.svg"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}
